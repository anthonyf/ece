(defun zone-compiler (initial-pc initial-val initial-env initial-proc initial-argl initial-continue initial-stack)
  (cl:let ((pc initial-pc)
           (val initial-val)
           (env initial-env)
           (proc initial-proc)
           (argl initial-argl)
           (continue initial-continue)
           (stack initial-stack)
           (bail cl:nil))
    (cl:loop
      (cl:when (cl:or (cl:>= pc 22820) (cl:< pc 0))
        (cl:return (cl:values pc val env proc argl continue stack)))
      (cl:cond
        ((cl:< pc 4096)
         (cl:multiple-value-setq (pc val env proc argl continue stack bail)
           (zone-compiler-chunk-0 pc val env proc argl continue stack)))
        ((cl:< pc 8192)
         (cl:multiple-value-setq (pc val env proc argl continue stack bail)
           (zone-compiler-chunk-1 pc val env proc argl continue stack)))
        ((cl:< pc 12288)
         (cl:multiple-value-setq (pc val env proc argl continue stack bail)
           (zone-compiler-chunk-2 pc val env proc argl continue stack)))
        ((cl:< pc 16384)
         (cl:multiple-value-setq (pc val env proc argl continue stack bail)
           (zone-compiler-chunk-3 pc val env proc argl continue stack)))
        ((cl:< pc 20480)
         (cl:multiple-value-setq (pc val env proc argl continue stack bail)
           (zone-compiler-chunk-4 pc val env proc argl continue stack)))
        ((cl:< pc 22820)
         (cl:multiple-value-setq (pc val env proc argl continue stack bail)
           (zone-compiler-chunk-5 pc val env proc argl continue stack)))
        (cl:t (cl:return (cl:values pc val env proc argl continue stack))))
      (cl:when bail
        (cl:return (cl:values pc val env proc argl continue stack))))))

;;; Self-registration: install zone-compiler under the space symbol so
;;; execute-instructions dispatches to it on entry to this space.
(cl:setf (cl:gethash '|compiler| *compiled-zone-functions*)
         (cl:function zone-compiler))
