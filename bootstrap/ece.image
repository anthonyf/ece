 ((ASSERT (EXPR . REST)
          ((IF (NULL? REST)
               (QUASIQUOTE
                (IF (NOT (UNQUOTE EXPR))
                    (ERROR "Assertion failed")
                    NIL))
               (QUASIQUOTE
                (IF (NOT (UNQUOTE EXPR))
                    (ERROR (UNQUOTE (CAR REST)))
                    NIL))))
          #65#)
  (PARAMETERIZE (BINDINGS . BODY)
   ((IF (NULL? BINDINGS)
        (QUASIQUOTE (BEGIN (UNQUOTE-SPLICING BODY)))
        (LET ((PARAM (CAR (CAR BINDINGS)))
              (VAL (CADR (CAR BINDINGS)))
              (REST (CDR BINDINGS)))
          (LET ((OLD (GENSYM)) (RESULT (GENSYM)))
            (QUASIQUOTE
             (LET (((UNQUOTE OLD) ((UNQUOTE PARAM))))
               ((UNQUOTE PARAM) (UNQUOTE VAL))
               (LET (((UNQUOTE RESULT)
                      (PARAMETERIZE (UNQUOTE REST) (UNQUOTE-SPLICING BODY))))
                 ((UNQUOTE PARAM) (UNQUOTE OLD) T)
                 (UNQUOTE RESULT))))))))
   #65#)
  (COLLECT (BINDING . BODY)
   ((QUASIQUOTE
     (MAP (LAMBDA ((UNQUOTE (CAR BINDING))) (UNQUOTE-SPLICING BODY))
          (UNQUOTE (CADR BINDING)))))
   #65#)
  (LOOP BODY ((LET ((GO-SYM (GENSYM)))
                (QUASIQUOTE
                 (CALL/CC
                  (LAMBDA (BREAK)
                    (LET (UNQUOTE GO-SYM)
                      NIL
                      (UNQUOTE-SPLICING BODY)
                      ((UNQUOTE GO-SYM)))))))) #65#)
  (DEFINE-RECORD (NAME . FIELDS)
   ((LET ((MAKE-NAME
           (STRING->SYMBOL (STRING-APPEND "make-" (SYMBOL->STRING NAME))))
          (PRED-NAME
           (STRING->SYMBOL (STRING-APPEND (SYMBOL->STRING NAME) "?")))
          (COPY-NAME
           (STRING->SYMBOL (STRING-APPEND "copy-" (SYMBOL->STRING NAME)))))
      (QUASIQUOTE
       (BEGIN
        (DEFINE ((UNQUOTE MAKE-NAME) (UNQUOTE-SPLICING FIELDS))
         (HASH-TABLE
          (UNQUOTE-SPLICING
           (APPLY APPEND
                  (CONS (LIST ''TYPE (LIST 'QUOTE NAME))
                        (MAP (LAMBDA (F) (LIST (LIST 'QUOTE F) F)) FIELDS))))))
        (DEFINE ((UNQUOTE PRED-NAME) OBJ)
         (AND (HASH-TABLE? OBJ) (EQ? (HASH-REF OBJ 'TYPE) '(UNQUOTE NAME))))
        (UNQUOTE-SPLICING
         (MAP
          (LAMBDA (F)
            (LET ((ACC-NAME
                   (STRING->SYMBOL
                    (STRING-APPEND (SYMBOL->STRING NAME) "-"
                     (SYMBOL->STRING F)))))
              (QUASIQUOTE
               (DEFINE ((UNQUOTE ACC-NAME) OBJ) (HASH-REF OBJ '(UNQUOTE F))))))
          FIELDS))
        (UNQUOTE-SPLICING
         (MAP
          (LAMBDA (F)
            (LET ((MUT-NAME
                   (STRING->SYMBOL
                    (STRING-APPEND "set-" (SYMBOL->STRING NAME) "-"
                     (SYMBOL->STRING F) "!"))))
              (QUASIQUOTE
               (DEFINE ((UNQUOTE MUT-NAME) OBJ VAL)
                (HASH-SET! OBJ '(UNQUOTE F) VAL)))))
          FIELDS))
        (UNQUOTE-SPLICING
         (MAP
          (LAMBDA (F)
            (LET ((WITH-NAME
                   (STRING->SYMBOL
                    (STRING-APPEND (SYMBOL->STRING NAME) "-with-"
                     (SYMBOL->STRING F)))))
              (QUASIQUOTE
               (DEFINE ((UNQUOTE WITH-NAME) OBJ VAL)
                (HASH-SET OBJ '(UNQUOTE F) VAL)))))
          FIELDS))
        (DEFINE ((UNQUOTE COPY-NAME) OBJ)
         (HASH-TABLE
          (UNQUOTE-SPLICING
           (APPLY APPEND
                  (CONS (LIST ''TYPE (LIST 'QUOTE NAME))
                        (MAP
                         (LAMBDA (F)
                           (LIST (LIST 'QUOTE F)
                                 (LIST
                                  (STRING->SYMBOL
                                   (STRING-APPEND (SYMBOL->STRING NAME) "-"
                                    (SYMBOL->STRING F)))
                                  'OBJ)))
                         FIELDS))))))))))
   #65#)
  (DO (BINDINGS
       TEST-AND-RESULT
       . BODY)
      ((DEFINE (VAR-INITS) (MAP (LAMBDA (B) (LIST (CAR B) (CADR B))) BINDINGS))
       (DEFINE (VAR-STEPS)
        (MAP
         (LAMBDA (B)
           (IF (NULL? (CDDR B))
               (CAR B)
               (CADDR B)))
         BINDINGS))
       (DEFINE (TEST-EXPR) (CAR TEST-AND-RESULT))
       (DEFINE (RESULT-EXPRS) (CDR TEST-AND-RESULT))
       (DEFINE (LOOP-NAME) (GENSYM))
       ((LAMBDA (NAME)
          (QUASIQUOTE
           (LET (UNQUOTE NAME)
             (UNQUOTE (VAR-INITS))
             (IF (UNQUOTE (TEST-EXPR))
                 (BEGIN
                  (UNQUOTE-SPLICING
                   (IF (NULL? (RESULT-EXPRS))
                       (LIST 'NIL)
                       (RESULT-EXPRS))))
                 (BEGIN (UNQUOTE-SPLICING BODY)
                  ((UNQUOTE NAME) (UNQUOTE-SPLICING (VAR-STEPS))))))))
        (LOOP-NAME)))
    #65#)
  (CASE (KEY . CLAUSES)
    ((DEFINE (EXPAND-CLAUSES K CLAUSES)
      (IF (NULL? CLAUSES)
          'NIL
          (IF (EQ? (CAAR CLAUSES) 'ELSE)
              (QUASIQUOTE (BEGIN (UNQUOTE-SPLICING (CDR (CAR CLAUSES)))))
              (QUASIQUOTE
               (IF (UNQUOTE
                    (IF (NULL? (CDR (CAAR CLAUSES)))
                        (QUASIQUOTE
                         (EQUAL? (UNQUOTE K) '(UNQUOTE (CAAR (CAR CLAUSES)))))
                        (QUASIQUOTE
                         (OR
                          (UNQUOTE-SPLICING
                           (MAP
                            (LAMBDA (D)
                              (QUASIQUOTE (EQUAL? (UNQUOTE K) '(UNQUOTE D))))
                            (CAAR CLAUSES)))))))
                   (BEGIN (UNQUOTE-SPLICING (CDR (CAR CLAUSES))))
                   (UNQUOTE (EXPAND-CLAUSES K (CDR CLAUSES))))))))
     (DEFINE (TEMP) (GENSYM))
     ((LAMBDA (G)
        (QUASIQUOTE
         ((LAMBDA ((UNQUOTE G)) (UNQUOTE (EXPAND-CLAUSES G CLAUSES)))
          (UNQUOTE KEY))))
      (TEMP)))
    #65#)
  (LETREC (BINDINGS . BODY)
   ((QUASIQUOTE
     (LET (UNQUOTE (MAP (LAMBDA (B) (LIST (CAR B) 'NIL)) BINDINGS))
       (UNQUOTE-SPLICING
        (MAP
         (LAMBDA (B) (QUASIQUOTE (SET (UNQUOTE (CAR B)) (UNQUOTE (CADR B)))))
         BINDINGS))
       (UNQUOTE-SPLICING BODY))))
   #65#)
  (UNLESS (TEST . BODY)
    ((QUASIQUOTE
      (IF (UNQUOTE TEST)
          NIL
          (BEGIN (UNQUOTE-SPLICING BODY)))))
    #65#)
  (WHEN (TEST . BODY)
    ((QUASIQUOTE
      (IF (UNQUOTE TEST)
          (BEGIN (UNQUOTE-SPLICING BODY))
          NIL)))
    #65#)
  (OR ARGS
      ((IF (NULL? ARGS)
           'NIL
           (IF (NULL? (CDR ARGS))
               (CAR ARGS)
               (LET ((TEMP (GENSYM)))
                 (QUASIQUOTE
                  (LET (((UNQUOTE TEMP) (UNQUOTE (CAR ARGS))))
                    (IF (UNQUOTE TEMP)
                        (UNQUOTE TEMP)
                        (OR (UNQUOTE-SPLICING (CDR ARGS))))))))))
      #65#)
  (AND ARGS
       ((IF (NULL? ARGS)
            'T
            (IF (NULL? (CDR ARGS))
                (CAR ARGS)
                (QUASIQUOTE
                 (IF (UNQUOTE (CAR ARGS))
                     (AND (UNQUOTE-SPLICING (CDR ARGS)))
                     NIL)))))
       #65#)
  (LET* (BINDINGS . BODY)
    ((IF (NULL? BINDINGS)
         (QUASIQUOTE (BEGIN (UNQUOTE-SPLICING BODY)))
         (QUASIQUOTE
          (LET ((UNQUOTE (CAR BINDINGS)))
            (LET* (UNQUOTE (CDR BINDINGS))
              (UNQUOTE-SPLICING BODY))))))
    #65#)
  (LET (BINDINGS . BODY)
    ((IF (SYMBOL? BINDINGS)
         (QUASIQUOTE
          (BEGIN
           (DEFINE ((UNQUOTE BINDINGS) (UNQUOTE-SPLICING (MAP CAR (CAR BODY))))
            (UNQUOTE-SPLICING (CDR BODY)))
           ((UNQUOTE BINDINGS) (UNQUOTE-SPLICING (MAP CADR (CAR BODY))))))
         (CONS
          (QUASIQUOTE
           (LAMBDA (UNQUOTE (MAP CAR BINDINGS)) (UNQUOTE-SPLICING BODY)))
          (MAP CADR BINDINGS))))
    #65#)
  (COND CLAUSES
        ((IF (NULL? CLAUSES)
             'NIL
             (IF (EQ? (CAAR CLAUSES) 'ELSE)
                 (QUASIQUOTE (BEGIN (UNQUOTE-SPLICING (CDR (CAR CLAUSES)))))
                 (QUASIQUOTE
                  (IF (UNQUOTE (CAAR CLAUSES))
                      (BEGIN (UNQUOTE-SPLICING (CDR (CAR CLAUSES))))
                      (COND (UNQUOTE-SPLICING (CDR CLAUSES))))))))
        #65#))
