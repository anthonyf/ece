#!/bin/sh
# ece-build — Build an ECE application for web or CL targets.
# Usage: ece-build --target web|cl [-o <dir>] [--standalone] <source.scm> ...
set -e

# ── ECE_HOME resolution ──
# Determine ECE SDK root relative to this script's location.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ECE_HOME="$(cd "$SCRIPT_DIR/.." && pwd)"

# ── Argument parsing ──
TARGET=""
OUTPUT_DIR=""
SOURCE_FILES=""
STANDALONE=0

usage() {
  echo "Usage: ece-build --target web|cl -o <dir> [--standalone] <source.scm> ..."
  echo ""
  echo "Options:"
  echo "  --target web|cl   Target platform (required)"
  echo "  -o <dir>          Output directory (required)"
  echo "  --standalone      Web: base64-encode all assets for file:// use"
  echo ""
  echo "Arguments:"
  echo "  <source.scm> ...  One or more .scm source files in dependency order"
  exit 1
}

while [ $# -gt 0 ]; do
  case "$1" in
    --target)
      shift
      [ $# -eq 0 ] && { echo "Error: --target requires an argument"; usage; }
      TARGET="$1"
      shift
      ;;
    -o)
      shift
      [ $# -eq 0 ] && { echo "Error: -o requires an argument"; usage; }
      OUTPUT_DIR="$1"
      shift
      ;;
    --standalone)
      STANDALONE=1
      shift
      ;;
    -h|--help)
      usage
      ;;
    -*)
      echo "Error: Unknown option: $1"
      usage
      ;;
    *)
      SOURCE_FILES="$SOURCE_FILES $1"
      shift
      ;;
  esac
done

# ── Input validation ──
if [ -z "$TARGET" ]; then
  echo "Error: --target is required"
  usage
fi

if [ "$TARGET" != "web" ] && [ "$TARGET" != "cl" ]; then
  echo "Error: --target must be 'web' or 'cl', got '$TARGET'"
  usage
fi

if [ -z "$OUTPUT_DIR" ]; then
  echo "Error: -o is required"
  usage
fi

if [ -z "$SOURCE_FILES" ]; then
  echo "Error: At least one source .scm file is required"
  usage
fi

# Validate source files exist
for f in $SOURCE_FILES; do
  if [ ! -f "$f" ]; then
    echo "Error: Source file not found: $f"
    exit 1
  fi
done

# ── Compilation step ──
# Build the Lisp expression to compile the source files into a bundle.
mkdir -p "$OUTPUT_DIR"
BUNDLE_PATH="$OUTPUT_DIR/app.ecec"

# Build a Lisp list of filenames
LISP_FILES=""
for f in $SOURCE_FILES; do
  # Use absolute paths for reliable loading
  ABS_F="$(cd "$(dirname "$f")" && pwd)/$(basename "$f")"
  LISP_FILES="$LISP_FILES \"$ABS_F\""
done

echo "Compiling $(echo $SOURCE_FILES | wc -w | tr -d ' ') file(s)..."
ABS_BUNDLE="$(cd "$(dirname "$BUNDLE_PATH")" 2>/dev/null && pwd)/$(basename "$BUNDLE_PATH")" \
  || ABS_BUNDLE="$(pwd)/$BUNDLE_PATH"

cd "$ECE_HOME"
qlot exec sbcl --noinform --non-interactive \
  --eval '(asdf:load-system :ece)' \
  --eval "(ece:evaluate (list (intern \"compile-system\" :ece) (list 'quote (list $LISP_FILES)) \"$ABS_BUNDLE\"))" \
  --quit
cd - > /dev/null

echo "Bundle: $BUNDLE_PATH"

# ── Target packaging ──
if [ "$TARGET" = "web" ]; then
  # ── Web target ──

  WASM_FILE="$ECE_HOME/wasm/runtime.wasm"
  GLUE_FILE="$ECE_HOME/wasm/glue.js"
  PRIMS_FILE="$ECE_HOME/wasm/primitives.json"
  BOOTSTRAP_FILE="$ECE_HOME/bootstrap/bootstrap.ecec"

  # Verify required files exist
  for f in "$WASM_FILE" "$GLUE_FILE" "$PRIMS_FILE" "$BOOTSTRAP_FILE"; do
    if [ ! -f "$f" ]; then
      echo "Error: Required file not found: $f"
      echo "Have you run 'make wasm' and 'make bootstrap' in the ECE directory?"
      exit 1
    fi
  done

  if [ "$STANDALONE" = "1" ]; then
    # ── Standalone mode (base64-in-JS for file:// compat) ──
    echo "Packaging for web (standalone)..."

    TEMPLATE="$ECE_HOME/templates/web/standalone.html"
    if [ ! -f "$TEMPLATE" ]; then
      echo "Error: Template not found: $TEMPLATE"
      exit 1
    fi

    # Generate ece-runtime.js (WASM binary base64 + glue code)
    echo "// ECE Runtime — auto-generated by ece-build" > "$OUTPUT_DIR/ece-runtime.js"
    printf '%s' "const ECE_PRIMITIVES = " >> "$OUTPUT_DIR/ece-runtime.js"
    cat "$PRIMS_FILE" >> "$OUTPUT_DIR/ece-runtime.js"
    echo ";" >> "$OUTPUT_DIR/ece-runtime.js"
    sed -e '/module\.exports/d' -e 's/require("\.\/primitives\.json")/ECE_PRIMITIVES/' "$GLUE_FILE" >> "$OUTPUT_DIR/ece-runtime.js"
    echo "" >> "$OUTPUT_DIR/ece-runtime.js"
    echo "// runtime.wasm as base64" >> "$OUTPUT_DIR/ece-runtime.js"
    printf '%s' "const ECE_WASM_BASE64 = \"" >> "$OUTPUT_DIR/ece-runtime.js"
    base64 -i "$WASM_FILE" | tr -d '\n' >> "$OUTPUT_DIR/ece-runtime.js"
    echo "\";" >> "$OUTPUT_DIR/ece-runtime.js"

    # Generate ece-bootstrap.js (single bootstrap bundle as base64)
    echo "// ECE Bootstrap — auto-generated by ece-build" > "$OUTPUT_DIR/ece-bootstrap.js"
    printf '%s' "const ECE_BOOTSTRAP_BUNDLE = \"" >> "$OUTPUT_DIR/ece-bootstrap.js"
    base64 -i "$BOOTSTRAP_FILE" | tr -d '\n' >> "$OUTPUT_DIR/ece-bootstrap.js"
    echo "\";" >> "$OUTPUT_DIR/ece-bootstrap.js"

    # Generate app.js (user .ecec bundle as JS data)
    echo "// App bundle — auto-generated by ece-build" > "$OUTPUT_DIR/app.js"
    printf '%s' "const ECE_APP_BUNDLE = \"" >> "$OUTPUT_DIR/app.js"
    base64 -i "$BUNDLE_PATH" | tr -d '\n' >> "$OUTPUT_DIR/app.js"
    echo "\";" >> "$OUTPUT_DIR/app.js"

    # Copy index.html template
    cp "$TEMPLATE" "$OUTPUT_DIR/index.html"

    echo "Standalone web app built in $OUTPUT_DIR/"
    echo "Open $OUTPUT_DIR/index.html in a browser to run."

  else
    # ── Server mode (raw files for HTTP serving) ──
    echo "Packaging for web (server mode)..."

    TEMPLATE="$ECE_HOME/templates/web/index.html"
    if [ ! -f "$TEMPLATE" ]; then
      echo "Error: Template not found: $TEMPLATE"
      exit 1
    fi

    # Generate ece-runtime.js (glue code only, no embedded WASM)
    echo "// ECE Runtime — auto-generated by ece-build" > "$OUTPUT_DIR/ece-runtime.js"
    printf '%s' "const ECE_PRIMITIVES = " >> "$OUTPUT_DIR/ece-runtime.js"
    cat "$PRIMS_FILE" >> "$OUTPUT_DIR/ece-runtime.js"
    echo ";" >> "$OUTPUT_DIR/ece-runtime.js"
    sed -e '/module\.exports/d' -e 's/require("\.\/primitives\.json")/ECE_PRIMITIVES/' "$GLUE_FILE" >> "$OUTPUT_DIR/ece-runtime.js"
    echo "" >> "$OUTPUT_DIR/ece-runtime.js"

    # Copy raw binary/text files
    cp "$WASM_FILE" "$OUTPUT_DIR/runtime.wasm"
    cp "$BOOTSTRAP_FILE" "$OUTPUT_DIR/bootstrap.ecec"
    # app.ecec already in OUTPUT_DIR from compilation step

    # Copy index.html template
    cp "$TEMPLATE" "$OUTPUT_DIR/index.html"

    echo "Server-mode web app built in $OUTPUT_DIR/"
    echo "Serve $OUTPUT_DIR/ over HTTP to run."
  fi

elif [ "$TARGET" = "cl" ]; then
  # ── CL target ──
  echo "Packaging for CL..."

  RUNTIME_FILE="$ECE_HOME/src/runtime.lisp"
  TEMPLATE="$ECE_HOME/templates/cl/run.lisp"

  # Verify required files exist
  for f in "$RUNTIME_FILE" "$TEMPLATE"; do
    if [ ! -f "$f" ]; then
      echo "Error: Required file not found: $f"
      exit 1
    fi
  done

  # Copy runtime and its required data files
  cp "$RUNTIME_FILE" "$OUTPUT_DIR/runtime.lisp"
  cp "$ECE_HOME/primitives.def" "$OUTPUT_DIR/"
  cp "$ECE_HOME/operations.def" "$OUTPUT_DIR/"

  # Copy bootstrap bundle
  mkdir -p "$OUTPUT_DIR/bootstrap"
  cp "$ECE_HOME/bootstrap/bootstrap.ecec" "$OUTPUT_DIR/bootstrap/"

  # Generate a dist-specific ASDF system definition
  # (runtime.lisp is at top level, not in src/)
  cat > "$OUTPUT_DIR/ece.asd" << 'EOFASD'
(require :asdf)
(in-package :asdf-user)
(defsystem "ece"
    :version "0.1.0"
    :description "ECE Runtime (standalone distribution)"
    :depends-on ()
    :serial t
    :components ((:file "runtime")))
EOFASD

  # Copy run.lisp template
  cp "$TEMPLATE" "$OUTPUT_DIR/run.lisp"

  echo "CL app built in $OUTPUT_DIR/"
  echo "Run with: sbcl --load $OUTPUT_DIR/run.lisp"
fi
