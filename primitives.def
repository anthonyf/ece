;;; ECE Primitive Manifest
;;; Canonical registry of all built-in primitives with stable numeric IDs.
;;;
;;; Format: (id name arity platform description)
;;;   id       - Stable numeric ID (never reused once assigned)
;;;   name     - ECE symbol name
;;;   arity    - Exact argument count, or -1 for variadic
;;;   platform - core (all runtimes), ece (implemented in prelude.scm),
;;;              cl (CL only), browser (browser only)
;;;   description - Human-readable description
;;;
;;; ID ranges:
;;;   0-99     Core primitives (all runtimes must implement)
;;;   100-199  CL platform primitives
;;;   200-299  Browser platform primitives (reserved, future)
;;;   300+     Future platforms
;;;
;;; IMPORTANT: IDs are permanent. Never reuse an ID for a different primitive.
;;; Gaps are allowed for future insertion within a range.

;;; ═══════════════════════════════════════════════════════════════════════
;;; CORE PRIMITIVES (0-99) — All runtimes must implement
;;; ═══════════════════════════════════════════════════════════════════════

;;; --- Arithmetic ---
(0   +                 -1   core   "Addition")
(1   -                 -1   core   "Subtraction")
(2   *                 -1   core   "Multiplication")
(3   /                 -1   core   "Division")
(4   modulo             2   ece    "Modulo/remainder (ECE-derived from floor)")

;;; --- Pair operations ---
(5   car                1   core   "First element of pair")
(6   cdr                1   core   "Rest of pair")
(7   cons               2   core   "Construct pair")
(8   list              -1   ece    "Construct list from arguments")
(9   set-car!           2   core   "Mutate car of pair")
(10  set-cdr!           2   core   "Mutate cdr of pair")

;;; --- Type predicates ---
(11  null?              1   core   "Test for empty list")
(12  pair?              1   core   "Test for pair/cons cell")
(13  number?            1   core   "Test for number")
(14  string?            1   core   "Test for string")
(15  symbol?            1   core   "Test for symbol")
(16  integer?           1   core   "Test for integer")
(17  char?              1   core   "Test for character")
(18  vector?            1   core   "Test for vector")
(19  boolean?           1   ece    "Test for boolean")

;;; --- Equality and comparison ---
(20  eq?                2   core   "Identity equality")
(21  equal?             2   ece    "Structural equality")
(22  =                 -1   core   "Numeric equality")
(23  <                 -1   core   "Numeric less-than")
(24  >                 -1   core   "Numeric greater-than")

;;; --- String operations ---
(25  string-length      1   core   "Length of string")
(26  string-ref         2   core   "Character at index in string")
(27  string-append     -1   core   "Concatenate strings")
(28  substring          3   core   "Extract substring")
(29  string->number     1   ece    "Parse number from string")
(30  number->string     1   ece    "Convert number to string")
(31  string->symbol     1   core   "Intern symbol from string")
(32  symbol->string     1   core   "Symbol name as string")
(33  string=?           2   ece    "String equality")
(34  string<?           2   ece    "String less-than")
(35  string>?           2   ece    "String greater-than")
(36  string-downcase    1   ece    "Lowercase string")
(37  string-upcase      1   ece    "Uppercase string")
(38  string-split       2   ece    "Split string by delimiter")
(39  string-trim        1   ece    "Trim whitespace from string")
(40  string-contains?   2   ece    "Test if string contains substring")
(41  string-join        2   ece    "Join list of strings with separator")
(42  string             1   core   "Convert character to string")

;;; --- Character operations ---
(43  char->integer      1   core   "Character to integer code point")
(44  integer->char      1   core   "Integer code point to character")
(45  char=?             2   ece    "Character equality")
(46  char<?             2   ece    "Character less-than")
(47  char-whitespace?   1   ece    "Test for whitespace character")
(48  char-alphabetic?   1   ece    "Test for alphabetic character")
(49  char-numeric?      1   ece    "Test for numeric character")

;;; --- Vector operations ---
(50  make-vector        -1  core   "Create vector of given size")
(51  vector             -1  core   "Create vector from arguments")
(52  vector-ref          2  core   "Element at index in vector")
(53  vector-set!         3  core   "Set element at index in vector")
(54  vector-length       1  core   "Length of vector")
(55  vector->list        1   ece   "Convert vector to list")
(56  list->vector        1   ece   "Convert list to vector")

;;; --- I/O operations ---
;;; IDs 57, 58, 59, 62 (display, write, newline, write-char) retired —
;;; these are now ECE procedures in prelude.scm built on %<op>-to-port.
;;; Low-level write primitives with required explicit ports live at IDs 179-183.
(60  read-char           1  core   "Read character from explicit port")
(61  peek-char           1  core   "Peek at next character from explicit port")
(63  read-line           1  core   "Read line from explicit port")
(64  char-ready?         1  core   "Test if character available on explicit port")
(65  eof?                1  core   "Test for end-of-file sentinel")
(66  print               1  ece    "Print object with newline")
(67  write-to-string     1  core   "Convert object to string representation")

;;; --- Port operations ---
(68  input-port?         1  core   "Test for input port")
(69  output-port?        1  core   "Test for output port")
(70  port?               1  core   "Test for any port")
;;; IDs 71, 72 (current-input-port, current-output-port) retired —
;;; these are now ECE parameter objects defined in prelude.scm.
(73  open-input-string   1  core   "Create input port from string")
(74  close-input-port    1  core   "Close input port")
(75  close-output-port   1  core   "Close output port")

;;; --- Bitwise operations ---
(76  bitwise-and        -1  core   "Bitwise AND")
(77  bitwise-or         -1  core   "Bitwise OR")
(78  bitwise-xor        -1  core   "Bitwise XOR")
(79  bitwise-not         1  core   "Bitwise NOT")
(80  arithmetic-shift    2  core   "Arithmetic shift left/right")

;;; --- Error handling ---
(81  %raw-error         -1  core   "Signal error with message")

;;; --- Miscellaneous ---
(82  gensym             -1  ece    "Generate unique interned symbol")
(83  sleep               1  core   "Pause execution for milliseconds")
(84  clear-screen        0  core   "Clear terminal/display")

;;; --- Compiler support primitives ---
(85  execute-from-pc    -1  core   "Execute instructions from program counter")
(86  get-macro           1  core   "Look up compile-time macro")
(87  set-macro!          2  core   "Set compile-time macro")
(88  make-parameter     -1  core   "Create parameter object (R7RS)")
(89  apply-compiled-procedure 2 core "Call compiled procedure with args")
(90  try-eval            1  core   "Evaluate with error handling")
(91  extend-environment -1  core   "Extend environment with new frame")

;;; --- Instruction vector / assembler support ---
(92  %intern-ece         1  core   "Intern string as ECE symbol")
(93  %instruction-vector-length 0 core "Length of global instruction vector")
(94  %instruction-vector-push!  1 core "Append instruction to global vector")
(95  %label-table-set!   2  core   "Set label in global label table")
(96  %label-table-ref    1  core   "Look up label in global label table")
(97  %procedure-name-set! 2 core   "Set procedure name for PC")

;;; --- Platform discovery ---
(98  platform-has?       1  core   "Test if named primitive is available")
(99  %platform-primitives 0 core   "List all available primitive names")

;;; ═══════════════════════════════════════════════════════════════════════
;;; CL PLATFORM PRIMITIVES (100-199) — CL runtime only
;;; ═══════════════════════════════════════════════════════════════════════

;;; --- File I/O (core — filesystem on CL, localStorage on WASM) ---
(100 open-input-file     1  core   "Open file for reading")
(101 open-output-file    1  core   "Open file for writing")
(102 with-input-from-file  2 core  "Scoped input redirection from file")
(103 with-output-to-file   2 core  "Scoped output redirection to file")
(104 write-byte            2  cl     "Write byte (0-255) to output port")
(105 open-binary-output-file 1 cl   "Open file for binary writing")

;;; --- Debugging ---
(106 trace               1  cl     "Enable tracing for procedure")
(107 untrace             1  cl     "Disable tracing for procedure")

;;; --- Integer rounding (core — both runtimes) ---
(108 truncate            1  core   "Truncate number toward zero to integer")
(109 floor               1  core   "Floor number toward -infinity to integer")
(110 exact->inexact      1  core   "Convert exact number to inexact (float)")
(112 %label-table-entries        0 cl "All label table entries")
(113 %macro-table-entries        0 cl "All macro table entries")
(114 parameter?                  1 core "Test if value is a parameter object")

;;; --- Hash table (CL-backed eq hash) ---
(116 %eq-hash-table      0  core   "Create empty eq hash table")
(117 %eq-hash-ref         2  core   "Look up key in eq hash table")
(118 %eq-hash-set!        3  core   "Set key in eq hash table")
(119 %eq-hash-has-key?    2  cl     "Test if key exists in eq hash table")
(120 %eq-hash-keys        1  cl     "List all keys in eq hash table")
(121 %hash-frame?         1  core   "Test for hash-table frame")
(122 %hash-frame-entries  1  cl     "All entries in hash-table frame")
(123 %make-hash-frame     0  cl     "Create empty hash-table frame")
(124 %hash-frame-set!     3  cl     "Set key in hash-table frame")

;;; --- Compilation spaces ---
(125 %create-space             1  core   "Create a new compilation space")
(126 %space-instruction-length 1  core   "Instruction count for a space")
(127 %space-name               1  core   "Name of a space")
(128 %current-space-id         0  core   "Current assembler target space ID")
(129 %set-current-space-id!    1  core   "Set current assembler target space ID")
(130 %space-instruction-push!  2  core   "Append instruction to a space")
(131 %space-label-set!         3  core   "Register label in a space")
(132 %space-label-ref          2  core   "Look up label in a space")
(133 %space-count              0  core   "Number of spaces in registry")
(134 %space-source-ref         2  core   "Get source instruction at index in a space")
(135 %space-label-entries      1  core   "Label table of a space as alist")
(136 write-to-string-flat      1  core    "Serialize to string without shared-structure markers")
(137 keyword?                  1  core   "Test if value is a keyword symbol")
(138 %primitive-name            1  core   "Get name symbol for primitive ID")
(139 %primitive-id              1  core   "Get numeric ID for primitive name")
(140 %global-env-frame          0  core   "First frame of *global-env* for identity check")

;;; --- Hash table primitives (core — all runtimes) ---
(141 %make-hash-table       0  core   "Create empty mutable hash table")
(142 hash-table?            1  core   "Test if value is a hash table")
(143 hash-ref              -1  core   "Look up key in hash table (optional default)")
(144 hash-set!              3  core   "Set key-value pair in hash table")
(145 hash-remove!           2  core   "Remove key from hash table")
(146 hash-has-key?          2  core   "Test if key exists in hash table")
(147 hash-keys              1  core   "List all keys in hash table")
(148 hash-values            1  core   "List all values in hash table")
(149 hash-count             1  core   "Number of entries in hash table")

;;; --- Yield (cooperative multitasking) ---
(150 %yield!                 1  core   "Store continuation, set yield flag, return to JS")
(151 current-milliseconds    0  core   "Milliseconds since page load (performance.now)")
(152 sin                     1  core   "Sine of angle in radians")
(153 cos                     1  core   "Cosine of angle in radians")
(196 sqrt                    1  core   "Square root of number")
(154 wall-clock-ms           0  core   "Milliseconds since midnight local time")

;;; --- Type introspection / save-load support ---
(155 compiled-procedure?       1  core   "Test if value is a compiled procedure")
(156 continuation?             1  core   "Test if value is a continuation")
(157 primitive?                1  core   "Test if value is a primitive procedure")
(228 procedure?                1  core   "Test if value is any callable procedure")
(158 compiled-procedure-entry  1  core   "Get entry address of compiled procedure")
(159 compiled-procedure-env    1  core   "Get captured environment of compiled procedure")
(160 continuation-stack        1  core   "Get saved stack from continuation")
(161 continuation-conts        1  core   "Get saved continue from continuation")
(162 %primitive-id-of          1  core   "Get numeric ID from primitive struct")
(163 %make-compiled-procedure  2  core   "Construct compiled procedure from entry+env")
(164 %make-continuation        3  core   "Construct continuation from stack+conts+winds")
(165 %make-primitive           1  core   "Construct primitive from numeric ID")

;;; --- Env-frame introspection / save-load support ---
(166 %env-frame?               1  core   "Test if value is an env-frame")
(167 %env-frame-names          1  core   "Get names list of env-frame")
(168 %env-frame-vals           1  core   "Get vals as a list from env-frame")
(169 %env-frame-enclosing      1  core   "Get enclosing frame (or nil)")
(170 %make-env-frame           3  core   "Construct env-frame from names, vals-list, enclosing")

;;; --- Winding stack support ---
(171 %set-winding-stack!       1  core   "Sync WAT winding-stack global with ECE *winding-stack*")
(172 %get-winding-stack        0  core   "Read WAT winding-stack global")
(173 continuation-winds        1  core   "Get saved winding stack from continuation")

;;; --- Additional equality ---
(174 eqv?                      2  ece    "Equivalence predicate")

;;; --- String output ports (R7RS) ---
(175 open-output-string         0  core   "Create output port that accumulates to string")
(176 get-output-string          1  core   "Extract accumulated string from output string port")
(177 port-line                  1  core   "Get current line number of port")
(178 port-col                   1  core   "Get current column number of port")

;;; --- Port-required write primitives (R7RS port ops, no ambient-port fallback) ---
(179 %display-to-port           2  core   "Write value to explicit port (human-readable form)")
(180 %write-to-port             2  core   "Write value to explicit port (machine-readable form)")
(181 %newline-to-port           1  core   "Write newline to explicit port")
(182 %write-char-to-port        2  core   "Write char to explicit port")
(183 %write-string-to-port      2  core   "Write string to explicit port")
(184 %initial-output-port       0  core   "Fresh output port wrapping host stdout (boot-time)")
(185 %initial-input-port        0  core   "Fresh input port wrapping host stdin (boot-time)")

;;; --- Process environment and filesystem (R7RS + ECE-specific) ---
(186 command-line               0  core   "Return argv as list of strings (R7RS)")
(187 exit                      -1  core   "Exit process with code (R7RS; 0-arg/int/#t/#f)")
(188 get-environment-variable   1  core   "Return env var value or #f (R7RS)")
(189 %exe-path                  0  core   "Resolved path of running executable")
(190 %list-directory            1  core   "List filenames in a directory")
(191 %file-exists?              1  core   "Test whether a file/directory exists")
(192 open-binary-input-file     1  core   "Open file for binary reading (R7RS)")
(193 read-byte                  1  core   "Read one byte (0-255) from port, or EOF")
(194 %make-directory            1  core   "Create directory and parents if missing")
(195 %chmod                     2  core   "Set POSIX file mode (path, mode-int)")

;;; ═══════════════════════════════════════════════════════════════════════
;;; BROWSER PLATFORM PRIMITIVES (200-299) — Canvas and DOM
;;; ═══════════════════════════════════════════════════════════════════════

;;; --- Canvas 2D drawing ---
(200 canvas-clear            0  browser "Clear entire canvas")
(201 canvas-set-fill-color   3  browser "Set fill color (r g b 0-255)")
(202 canvas-fill-rect        4  browser "Fill rectangle (x y w h)")
(203 canvas-fill-circle      3  browser "Fill circle (x y radius)")
(204 canvas-draw-text        3  browser "Draw text (x y string)")
(205 canvas-width            0  browser "Get canvas width in pixels")
(206 canvas-height           0  browser "Get canvas height in pixels")

;;; --- JavaScript FFI ---
(210 %js-eval              1  browser "Evaluate JS string, return js-ref")
(211 %js-get               2  browser "Get property (obj-ref prop-name)")
(212 %js-set!              3  browser "Set property (obj-ref prop-name val)")
(213 %js-call              3  browser "Call method (obj-ref method-name args-list)")
(214 %js-callback          1  browser "Wrap ECE proc as JS function")
(215 %js-ref->number       1  browser "Extract number from js-ref")
(216 %js-ref->string       1  browser "Extract string from js-ref")
(217 %js-number            1  browser "Wrap ECE number as js-ref")
(218 %js-string            1  browser "Wrap ECE string as js-ref")
(219 %js-null?             1  browser "Check for null/undefined js-ref")
(220 %js-release!          1  browser "Free a JS handle")
(221 %js-ref?              1  browser "Type predicate for js-ref values")

;;; ═══════════════════════════════════════════════════════════════════════
;;; BOOT REGISTRATION PRIMITIVES — Called from boot-env.ecec to initialize
;;; environment. No-ops on CL (already handled by init-primitive-dispatch-tables).
;;; ═══════════════════════════════════════════════════════════════════════

(222 %register-primitive!    2  core   "Register primitive by symbol name and numeric ID in global env")
(223 %init-asm-syms          1  core   "Allocate assembler symbol ID array of given size")
(224 %store-asm-sym          2  core   "Store symbol at slot in assembler symbol ID array")
(225 %set-continuation-syms! 2  core   "Cache do-winds! and *winding-stack* symbols for continuations")
(226 %set-error-sym!         1  core   "Cache error symbol for primitive type-error bridging")
(227 %create-repl-space!     2  core   "Create and activate default REPL compilation space")

;;; ═══════════════════════════════════════════════════════════════════════
;;; DEV-TOOLING PRIMITIVES (229-236) — TCP sockets and file watching for `ece serve`
;;; CL-only. Not portable to WASM.
;;; ═══════════════════════════════════════════════════════════════════════

(229 tcp-listen            2  cl     "Bind/listen on host:port; return server handle")
(230 tcp-accept-nowait     1  cl     "Non-blocking accept; return connection handle or #f")
(231 tcp-recv-nowait       2  cl     "Non-blocking read up to N bytes; byte list, symbol would-block, or symbol eof")
(232 tcp-send-nowait       2  cl     "Write byte list to connection; return bytes-sent count")
(233 tcp-close             1  cl     "Close TCP server or connection handle")
(234 fs-watch-start        1  cl     "Begin watching list of file paths; return watcher handle")
(235 fs-watch-poll         1  cl     "Non-blocking poll; return list of changed paths since last call")
(236 fs-watch-stop         1  cl     "Stop and remove a watcher")

;;; ═══════════════════════════════════════════════════════════════════════
;;; INTROSPECTION PRIMITIVES (237+) — global environment inspection
;;; ═══════════════════════════════════════════════════════════════════════

(237 %global-env-symbols    0  cl     "List all bound symbol names in global env")
(238 %procedure-params-set! 2  cl     "Store parameter metadata for a compiled procedure entry")
(239 %procedure-params      1  cl     "Look up parameter metadata for a callable value")
(240 %procedure-name-ref    1  core   "Look up registered name for a compiled procedure entry")
